rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidMemory(data) {
      return data.content is string && data.content.size() <= 1000 &&
             data.timestamp is timestamp &&
             data.userId == request.auth.uid &&
             (!('category' in data) || data.category is string);
    }

    match /memories/{memoryId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidMemory(request.resource.data) && isValidId(memoryId);
      allow delete: if isOwner(resource.data.userId);
      // Memories are generally immutable to represent fixed history
      allow update: if false;
    }
  }
}
